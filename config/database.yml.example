# PostgreSQL. In docker development, config/database.docker.yml is
# mounted over config/database.yml instead (see docker-compose.yml).
#
# In production, this file is provided by our ops scripts.
development:
  adapter: postgresql
  encoding: unicode
  database: wingolfsplattform_development
  pool: 5
  username: postgres
  password: YOUR PASSWORD HERE
  host: localhost

# Warning: The database defined as "test" will be erased and
# re-generated from db/schema.rb when you run the specs.
# Do not set this db to the same as development or production.
test:
  adapter: postgresql
  encoding: unicode
  database: wingolfsplattform_test<%= ENV['TEST_ENV_NUMBER'] %>
  pool: 5
  username: postgres
  password: YOUR PASSWORD HERE
  host: localhost

production:
  adapter: postgresql
  encoding: unicode
  database: wingolfsplattform_production
  pool: 25
  username: wingolfsplattform
  password:
  host: wingolfsplattform_postgres
