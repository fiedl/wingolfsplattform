#!/usr/bin/env ruby

# Run specs during development, dockerized:
#
#     bin/rspec spec/models/user_spec.rb
#     bin/rspec spec/models your_platform/spec/models
#     bin/rspec your_platform/spec/features/events_spec.rb
#
# The script re-runs itself in the tests container, prepares the
# environment (javascript modules, test database — at most once per
# day, see bin/setup.rb) and hands the arguments to rspec. CI uses
# bin/rspec_ci instead, which retries failed examples.

require_relative "docker_wrapper"
DockerWrapper.ensure_inside_docker! container: "tests", service_ports: true

require_relative "setup.rb"

# Feature specs drive the app through a real browser and need compiled
# assets. The assets live in a docker volume, so this is incremental
# after the first run.
if ARGV.empty? || ARGV.join(' ').include?('features')
  shell "bundle exec rails assets:precompile"
end

command = "bundle exec rspec #{ARGV.join(' ')}"
log.prompt command
exec(command)
