#!/usr/bin/env ruby

# Background job worker, dockerized:
#
#     bin/sidekiq
#
# The queue list matters: sidekiq only works queues it is told about.

require_relative "docker_wrapper"
DockerWrapper.ensure_inside_docker! container: "sidekiq"

system "/wait" if File.exist?("/wait")

exec "bundle exec sidekiq -c 10 -q default -q dag_links -q cache -q slow -q retry -q mailers -q mailgate --verbose"
