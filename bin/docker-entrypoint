#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency, if installed.
if [ -z "${LD_PRELOAD+x}" ] && [ -f /usr/lib/*/libjemalloc.so.2 ]; then
  export LD_PRELOAD="$(echo /usr/lib/*/libjemalloc.so.2)"
fi

# A previous container may have left a stale pid file behind.
rm -f tmp/pids/server.pid

exec "${@}"
