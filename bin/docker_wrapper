# This script can be sourced to ensure that a bin script is run inside
# docker. If it is called on the host, it re-runs itself in the given
# compose service:
#
#     #!/bin/bash
#     source bin/docker_wrapper
#     ensure_inside_docker tests "$@"
#
#     # Now run actual dev logic
#     echo "Running inside Docker"
#
# The re-run goes through bin/bundle_exec, which installs missing gems
# before executing the command.

inside_docker() {
  [ -f /.dockerenv ] && return 0
  grep -q docker /proc/1/cgroup 2>/dev/null && return 0
  [ "$DOCKER_BUILD" = "true" ]
}

ensure_inside_docker() {
  local service="$1"; shift
  inside_docker && return 0

  echo "\$ docker compose run --rm $service bin/bundle_exec bin/$(basename "$0") $*"
  exec docker compose run --rm "$service" bin/bundle_exec "bin/$(basename "$0")" "$@"
}
