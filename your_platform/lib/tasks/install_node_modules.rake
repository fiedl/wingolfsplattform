namespace :your_platform do
  namespace :install do

    # Installs the javascript modules and bundles the packs referenced by
    # the layouts (vendor/packs). Ran `bin/pack` before the demo app - and
    # its bin/ symlink - were removed.
    #
    # Plain `system` with exception: a failed yarn or webpack run must
    # fail the task. (The former fiedl-log shell wrapper invoked the
    # util-linux `script` command with a syntax that current images no
    # longer accept, so the packs silently never got built and feature
    # CI failed later with a misleading Sprockets::FileNotFound.)
    #
    task :node_modules => [:environment] do
      your_platform_path = File.expand_path(File.join(__FILE__, "../../.."))
      system "cd #{your_platform_path} && yarn install", exception: true
      system "cd #{your_platform_path} && ./node_modules/.bin/webpack --config config/webpack.config.js", exception: true
      system "ls #{your_platform_path}/vendor/packs", exception: true
    end
  end
end
