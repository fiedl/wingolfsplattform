#!/bin/bash

echo "Wingolfsplattform"

bundle install

cp /app/wingolfsplattform/config/database.docker.yml /app/wingolfsplattform/config/database.yml

# On first boot, the postgres container needs a moment to initialize.
until pg_isready -h "$POSTGRES_HOST" -q 2>/dev/null; do
  echo "Waiting for postgres ..."
  sleep 2
done

# bundle exec: a bare binary load mixes ruby's built-in bundler with the
# gem-installed one from the lockfile and crashes with
# "Bundler::GemfileError is already registered".
bundle exec rails db:create
# A fresh database gets the schema from db/schema.rb: the migration
# history contains mysql-only SQL and is not replayed on postgres.
if bundle exec rails db:version 2>/dev/null | grep -q "Current version: 0"; then
  bundle exec rails db:schema:load
fi
bundle exec rails db:migrate
bundle exec rails your_platform:install:node_modules || echo 'task not found'

bundle exec puma
